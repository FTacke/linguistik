{
  "extends": [
    "development"
  ],
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 26.4",
    "not safari <= 26.4",
    "not chrome <= 109"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "border-left: 3px solid color-mix(in srgb, var(--book-accent) 30%, transparent)"
        ]
      }
    ]
  }
}